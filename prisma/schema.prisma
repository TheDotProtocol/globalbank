// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String    @id @default(cuid())
  email                 String    @unique
  password              String
  firstName             String
  lastName              String
  phone                 String?
  kycStatus             KycStatus @default(PENDING)
  emailVerified         Boolean   @default(false)
  emailVerifiedAt       DateTime?
  emailVerificationToken String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  twoFactorSecret       String?
  twoFactorEnabled      Boolean   @default(false)
  twoFactorVerifiedAt   DateTime?
  branchId              String?
  sumsubApplicantId     String?
  pepStatus             PepStatus           @default(NONE)
  riskRating            CustomerRiskRating  @default(LOW)
  lastKycReviewAt       DateTime?
  primaryJurisdiction   Jurisdiction?

  // Relations
  branch                Branch?   @relation(fields: [branchId], references: [id])
  accounts              Account[]
  transactions          Transaction[]
  cards                 Card[]
  fixedDeposits         FixedDeposit[]
  kycDocuments          KycDocument[]
  aiInteractions        AiInteraction[]
  eChecks               ECheck[]
  payments              Payment[]
  internationalTransfers InternationalTransfer[]
  amlCases              AmlCase[]
  loanApplications      LoanApplication[]
  loans                 Loan[]

  @@map("users")
}

model Account {
  id            String      @id @default(cuid())
  userId        String
  accountNumber String      @unique
  accountType   AccountType @default(SAVINGS)
  balance       Decimal     @default(0)
  holdAmount    Decimal     @default(0)
  subLedgerCode String?     @unique
  currency      String      @default("USD")
  isActive      Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  loanApplications LoanApplication[]
  loans            Loan[]
  transactions  Transaction[]
  cards         Card[]
  eChecks       ECheck[]
  bankTransfers BankTransfer[]
  payments      Payment[]
  fixedDeposits FixedDeposit[]
  internationalTransfers InternationalTransfer[]

  @@map("accounts")
}

model Transaction {
  id          String        @id @default(cuid())
  accountId   String
  type        TransactionType
  amount      Decimal
  description String
  reference   String?       @unique
  utr         String?       @unique
  status      TransactionStatus @default(PENDING)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Enhanced transfer details
  transferMode TransferMode?
  sourceAccountId String?
  destinationAccountId String?
  sourceAccountNumber String?
  destinationAccountNumber String?
  sourceAccountHolder String?
  destinationAccountHolder String?
  transferFee Decimal @default(0)
  netAmount Decimal?
  
  // Dispute fields
  isDisputed  Boolean       @default(false)
  disputeReason String?
  disputeStatus DisputeStatus @default(NONE)
  disputeCreatedAt DateTime?
  disputeResolvedAt DateTime?
  disputeResolution String?

  // Compliance / AML
  branchId          String?
  complianceStatus  ComplianceStatus @default(CLEAR)
  complianceFlag    ComplianceFlag?
  flagReason        String?
  flaggedAt         DateTime?
  flaggedBy         String?
  reviewedAt        DateTime?
  reviewedBy        String?
  reviewNotes       String?
  riskScore         Int              @default(0)

  // Relations
  branch            Branch?           @relation(fields: [branchId], references: [id])
  complianceReviews ComplianceReview[]
  account     Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  @@map("transactions")
}

model Card {
  id            String    @id @default(cuid())
  userId        String
  accountId     String
  cardNumber    String    @unique
  cardType      CardType
  status        CardStatus @default(ACTIVE)
  expiryDate    DateTime
  cvv           String
  isVirtual     Boolean   @default(false)
  isActive      Boolean   @default(true)
  dailyLimit    Decimal   @default(1000)
  monthlyLimit  Decimal   @default(5000)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("cards")
}

model FixedDeposit {
  id            String        @id @default(cuid())
  userId        String
  accountId     String
  amount        Decimal
  interestRate  Decimal
  duration      Int           // in months
  maturityDate  DateTime
  status        DepositStatus @default(ACTIVE)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("fixed_deposits")
}

model KycDocument {
  id            String        @id @default(cuid())
  userId        String
  documentType  DocumentType
  documentUrl   String
  fileName      String
  fileSize      Int
  mimeType      String
  s3Key         String?       // S3 object key
  status        DocumentStatus @default(PENDING)
  rejectionReason String?
  verifiedAt    DateTime?
  verifiedBy    String?       // Admin ID who verified
  notes         String?       // Admin notes
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("kyc_documents")
}

model AiInteraction {
  id            String      @id @default(cuid())
  userId        String
  category      AiCategory
  question      String
  answer        String
  createdAt     DateTime    @default(now())

  // Relations
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_interactions")
}

model ECheck {
  id            String      @id @default(cuid())
  userId        String
  accountId     String
  checkNumber   String      @unique
  payeeName     String
  amount        Decimal
  currency      String      @default("USD")
  memo          String?
  signatureUrl  String?     // S3 URL for signature image
  status        CheckStatus @default(PENDING)
  clearedAt     DateTime?
  processedAt   DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("e_checks")
}

model CorporateBank {
  id                String    @id @default(cuid())
  bankName          String
  accountHolderName String
  accountNumber     String    @unique
  swiftCode         String?
  bicCode           String?
  accountType       String
  currency          String    @default("THB")
  transferFee       Decimal   @default(50)
  isActive          Boolean   @default(true)
  apiEndpoint       String?
  apiKey            String?
  routingNumber     String?
  iban              String?
  country           String?
  city              String?
  address           String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  bankTransfers     BankTransfer[]

  @@map("corporate_banks")
}

model BankTransfer {
  id                String            @id @default(cuid())
  corporateBankId   String
  fromAccountId     String?
  toAccountNumber   String
  toAccountName     String
  amount            Decimal
  currency          String            @default("THB")
  transferType      BankTransferType
  status            BankTransferStatus @default(PENDING)
  reference         String            @unique
  description       String?
  fee               Decimal           @default(0)
  netAmount         Decimal?
  processedAt       DateTime?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  // Relations
  corporateBank     CorporateBank     @relation(fields: [corporateBankId], references: [id], onDelete: Cascade)
  account           Account?          @relation(fields: [fromAccountId], references: [id], onDelete: SetNull)

  @@map("bank_transfers")
}

// Enums
enum AccountType {
  SAVINGS
  CHECKING
  FIXED_DEPOSIT
  BUSINESS
}

enum TransactionType {
  CREDIT
  DEBIT
  TRANSFER
  WITHDRAWAL
  DEPOSIT
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum DisputeStatus {
  NONE
  PENDING
  UNDER_REVIEW
  RESOLVED
  REJECTED
}

enum CardType {
  DEBIT
  CREDIT
  VIRTUAL
}

enum CardStatus {
  ACTIVE
  INACTIVE
  EXPIRED
  BLOCKED
}

enum DepositStatus {
  ACTIVE
  MATURED
  WITHDRAWN
  CANCELLED
}

enum KycStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum DocumentType {
  ID_PROOF
  ADDRESS_PROOF
  INCOME_PROOF
  BANK_STATEMENT
  SELFIE_PHOTO
  LIVELINESS_VIDEO
  PASSPORT
  DRIVERS_LICENSE
  NATIONAL_ID
  UTILITY_BILL
  RENTAL_AGREEMENT
  EMPLOYMENT_LETTER
  PAYSLIP
  TAX_RETURN
  BUSINESS_LICENSE
  ARTICLES_OF_INCORPORATION
  PROOF_OF_FUNDS
  SOURCE_OF_WEALTH
  POLITICALLY_EXPOSED_PERSON
  SANCTIONS_CHECK
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum AiCategory {
  FINANCIAL_LITERACY
  INVESTMENT_GUIDANCE
  SECURITY_EDUCATION
  AUTOMATION_ASSISTANCE
  GENERAL_QUERY
}

enum CheckStatus {
  PENDING
  SIGNED
  CLEARED
  REJECTED
}

enum TransferMode {
  INTERNAL_TRANSFER
  EXTERNAL_TRANSFER
  WIRE_TRANSFER
  ACH_TRANSFER
  CARD_TRANSFER
  MOBILE_TRANSFER
  INTERNATIONAL_TRANSFER
}

enum BankTransferType {
  INBOUND   // Money coming into user account from corporate bank
  OUTBOUND  // Money going out from user account to corporate bank
}

enum BankTransferStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REVERSED
}

enum TransferStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REVERSED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  EXPIRED
  CANCELLED
}

enum PaymentMethod {
  CARD
  BANK_TRANSFER
  THAI_QR
  INDIA_UPI
  WIRE_TRANSFER
  MOBILE_PAYMENT
}

model Payment {
  id            String        @id @default(cuid())
  userId        String
  accountId     String
  amount        Decimal
  currency      String        @default("USD")
  paymentMethod PaymentMethod
  status        PaymentStatus @default(PENDING)
  reference     String        @unique
  description   String?
  metadata      Json?
  completedAt   DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account       Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("payments")
}

model InternationalTransfer {
  id                String        @id @default(cuid())
  userId            String
  accountId         String
  transactionId    String
  amount            Decimal
  currency          String        @default("USD")
  targetCurrency    String        @default("USD")
  exchangeRate      Decimal
  convertedAmount   Decimal
  transferFee       Decimal
  totalAmount       Decimal
  beneficiaryName   String
  beneficiaryAddress String?
  beneficiaryCity   String?
  beneficiaryCountry String
  bankName          String
  bankAddress       String?
  swiftCode         String
  accountNumber     String
  routingNumber     String?
  description       String?
  reference         String        @unique
  utr               String?       @unique
  status            TransferStatus @default(PENDING)
  estimatedDelivery DateTime
  completedAt       DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Relations
  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  account           Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("international_transfers")
}

model Branch {
  id           String        @id @default(cuid())
  name         String
  country      String
  city         String
  address      String
  region       String?
  isHQ         Boolean       @default(false)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  users        User[]
  transactions Transaction[]

  @@map("branches")
}

model ComplianceReview {
  id              String   @id @default(cuid())
  transactionId   String
  action          ComplianceAction
  notes           String?
  reviewedBy      String
  reviewerRole    String
  createdAt       DateTime @default(now())
  transaction     Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@map("compliance_reviews")
}

enum ComplianceStatus {
  CLEAR
  FLAGGED
  UNDER_REVIEW
  APPROVED
  ON_HOLD
  REJECTED
  REPORTED
}

enum ComplianceFlag {
  HIGH_AMOUNT
  RAPID_SUCCESSION
  UNUSUAL_PATTERN
  INTERNATIONAL_HIGH_RISK
  STRUCTURING
  MANUAL_FLAG
}

enum ComplianceAction {
  APPROVE
  HOLD
  REJECT
  REPORT
  ESCALATE
}

// ─── Regulatory infrastructure (RBI / BOT readiness) ───────────────────────

enum ActorType {
  USER
  ADMIN
  SYSTEM
  COMPLIANCE
}

enum LedgerAccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum SettlementType {
  INTERNAL
  INTERNATIONAL
  EXTERNAL_IN
  EXTERNAL_OUT
  FEE
  MANUAL
}

enum SettlementStatus {
  PENDING
  SETTLED
  FAILED
  REVERSED
  HELD
}

enum RegulatoryReportType {
  SAR
  STR
  CTR
  AML_MONTHLY
  SUSPICIOUS_ACTIVITY
}

enum ReportStatus {
  DRAFT
  PENDING_REVIEW
  SUBMITTED
  ACKNOWLEDGED
  CLOSED
}

enum ManualEntryStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
  EXECUTED
}

model AuditLog {
  id          String    @id @default(cuid())
  actorType   ActorType
  actorId     String?
  actorEmail  String?
  action      String
  entityType  String
  entityId    String?
  beforeState Json?
  afterState  Json?
  ipAddress   String?
  userAgent   String?
  metadata    Json?
  createdAt   DateTime  @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model LedgerAccount {
  id        String            @id @default(cuid())
  code      String            @unique
  name      String
  type      LedgerAccountType
  currency  String            @default("USD")
  balance   Decimal           @default(0)
  isActive  Boolean           @default(true)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  entries   LedgerEntry[]

  @@map("ledger_accounts")
}

model SettlementRecord {
  id            String           @id @default(cuid())
  transactionId String?          @unique
  reference     String           @unique
  type          SettlementType
  status        SettlementStatus @default(PENDING)
  amount        Decimal
  currency      String           @default("USD")
  settledAt     DateTime?
  externalRef   String?
  metadata      Json?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  entries       LedgerEntry[]

  @@index([status])
  @@index([type])
  @@map("settlement_records")
}

model LedgerEntry {
  id              String           @id @default(cuid())
  journalId       String
  ledgerAccountId String
  debit           Decimal          @default(0)
  credit          Decimal          @default(0)
  currency        String           @default("USD")
  description     String
  transactionId   String?
  settlementId    String?
  createdBy       String
  createdAt       DateTime         @default(now())
  ledgerAccount   LedgerAccount    @relation(fields: [ledgerAccountId], references: [id])
  settlement      SettlementRecord? @relation(fields: [settlementId], references: [id])

  @@index([journalId])
  @@index([transactionId])
  @@index([settlementId])
  @@map("ledger_entries")
}

model RegulatoryReport {
  id             String               @id @default(cuid())
  reportType     RegulatoryReportType
  jurisdiction   String
  status         ReportStatus         @default(DRAFT)
  reference      String               @unique
  transactionIds Json?
  userId         String?
  filedBy        String
  filedAt        DateTime?
  content        Json
  notes          String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([reportType])
  @@index([jurisdiction])
  @@index([status])
  @@map("regulatory_reports")
}

model PendingManualEntry {
  id          String            @id @default(cuid())
  createdBy   String
  approvedBy  String?
  status      ManualEntryStatus @default(PENDING_APPROVAL)
  entryType   String
  payload     Json
  notes       String?
  createdAt   DateTime          @default(now())
  approvedAt  DateTime?
  executedAt  DateTime?

  @@index([status])
  @@index([createdBy])
  @@map("pending_manual_entries")
}

enum Jurisdiction {
  BVI
  LABUAN
  THAILAND
  INDIA
}

enum LicenseStatus {
  PLANNED
  APPLICATION_SUBMITTED
  CONDITIONAL
  ACTIVE
  SUSPENDED
  REVOKED
}

enum GovernanceRoleType {
  BOARD_CHAIR
  CEO
  CFO
  CRO
  MLRO
  COMPLIANCE_OFFICER
  COMPANY_SECRETARY
}

enum PepStatus {
  NONE
  PEP
  RCA
}

enum CustomerRiskRating {
  LOW
  MEDIUM
  HIGH
  PROHIBITED
}

enum AmlCaseStatus {
  OPEN
  INVESTIGATING
  ESCALATED
  SAR_FILED
  CLOSED
}

enum AmlCasePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LoanApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  WITHDRAWN
}

enum LoanStatus {
  PENDING_DISBURSEMENT
  ACTIVE
  PAID_OFF
  DEFAULTED
  WRITTEN_OFF
}

enum LoanPaymentStatus {
  SCHEDULED
  PAID
  LATE
  MISSED
}

enum SafeguardingPurpose {
  CUSTOMER_FUNDS
  OPERATIONAL
  CAPITAL_RESERVE
}

model BankLicense {
  id              String          @id @default(cuid())
  jurisdiction    Jurisdiction
  licenseType     String
  status          LicenseStatus   @default(PLANNED)
  licenseNumber   String?
  regulatorName   String
  capitalRequired Decimal         @default(0)
  capitalHeld     Decimal         @default(0)
  appliedAt       DateTime?
  grantedAt       DateTime?
  expiresAt       DateTime?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@unique([jurisdiction, licenseType])
  @@index([status])
  @@map("bank_licenses")
}

model GovernanceRole {
  id            String             @id @default(cuid())
  jurisdiction  Jurisdiction
  role          GovernanceRoleType
  holderName    String
  holderEmail   String?
  appointedAt   DateTime?
  isActive      Boolean            @default(true)
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([jurisdiction])
  @@index([role])
  @@map("governance_roles")
}

model AmlCase {
  id              String          @id @default(cuid())
  reference       String          @unique
  userId          String?
  transactionId   String?
  status          AmlCaseStatus   @default(OPEN)
  priority        AmlCasePriority @default(MEDIUM)
  title           String
  description     String?
  assignee        String?
  sanctionsHit    Boolean         @default(false)
  fraudScore      Int             @default(0)
  resolution      String?
  openedAt        DateTime        @default(now())
  closedAt        DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User?           @relation(fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
  @@index([priority])
  @@map("aml_cases")
}

model SafeguardingAccount {
  id            String              @id @default(cuid())
  jurisdiction  Jurisdiction
  purpose       SafeguardingPurpose @default(CUSTOMER_FUNDS)
  bankName      String
  accountNumber String
  accountName   String
  currency      String              @default("USD")
  balance       Decimal             @default(0)
  isActive      Boolean             @default(true)
  notes         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([jurisdiction])
  @@map("safeguarding_accounts")
}

model LoanProduct {
  id              String   @id @default(cuid())
  name            String
  jurisdiction    Jurisdiction
  minAmount       Decimal
  maxAmount       Decimal
  minTermMonths   Int
  maxTermMonths   Int
  baseApr         Decimal
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  applications    LoanApplication[]
  loans           Loan[]

  @@map("loan_products")
}

model LoanApplication {
  id              String                @id @default(cuid())
  reference       String                @unique
  userId          String
  accountId       String
  productId       String
  requestedAmount Decimal
  termMonths      Int
  purpose         String?
  status          LoanApplicationStatus @default(SUBMITTED)
  reviewedBy      String?
  reviewNotes     String?
  submittedAt     DateTime              @default(now())
  reviewedAt      DateTime?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  user            User                  @relation(fields: [userId], references: [id])
  account         Account               @relation(fields: [accountId], references: [id])
  product         LoanProduct           @relation(fields: [productId], references: [id])
  loan            Loan?

  @@index([status])
  @@index([userId])
  @@map("loan_applications")
}

model Loan {
  id              String     @id @default(cuid())
  reference       String     @unique
  applicationId   String     @unique
  userId          String
  accountId       String
  productId       String
  principal       Decimal
  outstanding     Decimal
  apr             Decimal
  termMonths      Int
  status          LoanStatus @default(PENDING_DISBURSEMENT)
  disbursedAt     DateTime?
  maturityDate    DateTime?
  provisionRate   Decimal    @default(0)
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  application     LoanApplication @relation(fields: [applicationId], references: [id])
  user            User            @relation(fields: [userId], references: [id])
  account         Account         @relation(fields: [accountId], references: [id])
  product         LoanProduct     @relation(fields: [productId], references: [id])
  schedule        LoanSchedulePayment[]

  @@index([status])
  @@index([userId])
  @@map("loans")
}

model LoanSchedulePayment {
  id            String            @id @default(cuid())
  loanId        String
  installmentNo Int
  dueDate       DateTime
  principalDue  Decimal
  interestDue   Decimal
  totalDue      Decimal
  status        LoanPaymentStatus @default(SCHEDULED)
  paidAt        DateTime?
  createdAt     DateTime          @default(now())
  loan          Loan              @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
  @@map("loan_schedule_payments")
}

model LedgerReconciliation {
  id                  String   @id @default(cuid())
  runDate             DateTime @default(now())
  customerBalanceSum  Decimal
  subLedgerBalanceSum Decimal
  poolBalance         Decimal
  variance            Decimal
  status              String   @default("OK")
  breaks              Json?
  createdAt           DateTime @default(now())

  @@index([runDate])
  @@map("ledger_reconciliations")
}